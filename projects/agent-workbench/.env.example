# Copy to .env and fill in. Load it however you like (direnv, dotenv, `export $(cat .env)`).

# Required to actually run the agent (the CLI and eval runner).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional tuning (defaults shown) ---
# Which model the agent uses. Opus 4.8 is most capable; switch to
# claude-sonnet-4-6 or claude-haiku-4-5 for cheaper loops.
# AGENT_MODEL=claude-opus-4-8

# Max output tokens per LLM call.
# AGENT_MAX_TOKENS=16000

# Reasoning/cost knob: low | medium | high | xhigh | max
# AGENT_EFFORT=high

# Adaptive thinking on/off (1/0). On = the model shows reasoning summaries.
# AGENT_THINKING=1

# Hard cap on agent loop turns (stops runaway loops).
# AGENT_MAX_TURNS=20

# Where JSONL traces are written.
# AGENT_TRACE_DIR=traces
